# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Marine Track bot defaults
MARINE_TRACK_DEFAULT_AOI=data/aoi/example_black_sea.geojson
MARINE_TRACK_OUTPUT_DIR=runs/telegram
MARINE_TRACK_DEFAULT_SENSOR=auto
MARINE_TRACK_DEFAULT_LOOKBACK_HOURS=72
MARINE_TRACK_MAX_RESULTS=10
MARINE_TRACK_MAX_CONCURRENT_JOBS=1

# Provider dependency profile installed by install/deploy scripts.
# all = scene + auxiliary provider packages; scene = STAC/ASF/Sentinel Hub; aux = Copernicus Marine; core/none = skip provider packages.
MARINE_TRACK_PROVIDER_PROFILE=all

# Detection defaults
# Current MVP detector uses local-CFAR style detection on a single GeoTIFF/COG raster band.
# Detailed parameters are stored in config/processing.yaml and written into report.json.
MARINE_TRACK_DETECTION_MAX_CROPS=10

# Optional land/shoreline suppression.
# GeoJSON must contain land polygons in EPSG:4326 lon/lat coordinates.
MARINE_TRACK_LAND_MASK_GEOJSON=
MARINE_TRACK_SHORELINE_BUFFER_M=500

# NASA Earthdata / ASF.
# Search works without credentials; authenticated download uses username/password or EDL token.
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
EARTHDATA_TOKEN=

# Copernicus Data Space Ecosystem STAC/OData access.
# Username/password use the CDSE public client unless CDSE_CLIENT_ID is set.
CDSE_ACCESS_TOKEN=
CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
CDSE_CLIENT_ID=cdse-public
CDSE_CLIENT_SECRET=
CDSE_USERNAME=
CDSE_PASSWORD=

# Sentinel Hub Catalog/Process access.
# Use services.sentinel-hub.com by default; for CDSE Sentinel Hub services set the CDSE catalog/token URLs.
SENTINELHUB_ACCESS_TOKEN=
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
SENTINELHUB_TOKEN_URL=https://services.sentinel-hub.com/auth/realms/main/protocol/openid-connect/token
SENTINELHUB_CATALOG_URL=https://services.sentinel-hub.com/api/v1/catalog/1.0.0/search

# Copernicus Marine Toolbox.
COPERNICUSMARINE_SERVICE_USERNAME=
COPERNICUSMARINE_SERVICE_PASSWORD=

# AIS / vessel track validation.
MARINE_TRACK_AIS_CSV=
NOAA_MARINECADASTRE_BASE_URL=
NOAA_MARINECADASTRE_CACHE_DIR=runs/noaa_ais

# Runtime
PYTHONUNBUFFERED=1
