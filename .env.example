# Telegram bot
# Create a bot and token: https://t.me/BotFather
# Official guide: https://core.telegram.org/bots/tutorial
TELEGRAM_BOT_TOKEN=
# Fail-closed by default: set at least one numeric Telegram user id.
# Send a message to the new bot and use Bot API getUpdates as described in README.
TELEGRAM_ADMIN_IDS=
# Explicit opt-in for a public bot. Leave 0 for production/admin-only operation.
MARINE_TRACK_ALLOW_PUBLIC_BOT=0

# Marine Track bot defaults
MARINE_TRACK_DEFAULT_AOI=data/aoi/example_black_sea.geojson
MARINE_TRACK_OUTPUT_DIR=runs/telegram
MARINE_TRACK_DEFAULT_SENSOR=sentinel1
MARINE_TRACK_DEFAULT_LOOKBACK_HOURS=72
MARINE_TRACK_MAX_RESULTS=10
MARINE_TRACK_MAX_CONCURRENT_JOBS=1

# Provider dependency profile installed by install/deploy scripts.
# scene = recommended operational profile: STAC/ASF/Sentinel Hub.
# all = scene + auxiliary Copernicus Marine packages.
# aux = Copernicus Marine only; core = no provider extras.
MARINE_TRACK_PROVIDER_PROFILE=scene

# Cache policy.
MARINE_TRACK_CACHE_DIR=runs/cache
MARINE_TRACK_SCENE_SEARCH_TTL_MIN=30
MARINE_TRACK_SCENE_SEARCH_CACHE_RETENTION_DAYS=7
MARINE_TRACK_RASTER_CACHE_RETENTION_DAYS=14
MARINE_TRACK_MASK_CACHE_RETENTION_DAYS=90
MARINE_TRACK_DETECTION_OUTPUT_RETENTION_DAYS=7
MARINE_TRACK_RUN_OUTPUT_RETENTION_DAYS=7
MARINE_TRACK_CLEANUP_ON_DEPLOY=1

# Detection effective config. YAML is the baseline; non-empty env values override it.
MARINE_TRACK_PROCESSING_CONFIG=config/processing.yaml
MARINE_TRACK_DETECTION_MAX_CROPS=10
MARINE_TRACK_DETECTION_THRESHOLD_SIGMA=
MARINE_TRACK_DETECTION_MIN_AREA_PX=
MARINE_TRACK_DETECTION_MAX_AREA_PX=
MARINE_TRACK_DETECTION_LOCAL_WINDOW_PX=
MARINE_TRACK_DETECTION_GUARD_WINDOW_PX=
MARINE_TRACK_DETECTION_MIN_CONTRAST_SIGMA=
MARINE_TRACK_CFAR_MIN_TRAINING_FRACTION=0.5
MARINE_TRACK_DETECTION_TILE_SIZE_PX=1024
MARINE_TRACK_DETECTION_TILE_OVERLAP_PX=128
MARINE_TRACK_NORMALIZATION_SAMPLE_PIXELS=1000000
# Default menu action derives a compact sector from the configured AOI. The 16 km
# side stays below the independent 400 km² detection ceiling after geodesic rounding.
MARINE_TRACK_DEFAULT_DETECTION_SIDE_KM=16
MARINE_TRACK_MAX_DETECTION_AOI_AREA_KM2=400
# Entire materialize/preprocess/detect/render worker wall-clock limit.
MARINE_TRACK_DETECTION_JOB_TIMEOUT_S=300

# Bounded GDAL HTTP access used inside the isolated detection worker.
MARINE_TRACK_GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
MARINE_TRACK_GDAL_ALLOWED_EXTENSIONS=.tif,.tiff
MARINE_TRACK_GDAL_HTTP_CONNECT_TIMEOUT_S=10
MARINE_TRACK_GDAL_HTTP_TIMEOUT_S=45
MARINE_TRACK_GDAL_HTTP_LOW_SPEED_LIMIT_BPS=1024
MARINE_TRACK_GDAL_HTTP_LOW_SPEED_TIME_S=30
MARINE_TRACK_GDAL_HTTP_MAX_RETRY=2
MARINE_TRACK_GDAL_HTTP_RETRY_DELAY_S=1

# Sensor preprocessing and research gates.
# Sentinel-1 is the operational single-raster baseline. Unknown/amplitude products are
# converted only to relative dB and are not advertised as absolutely calibrated.
MARINE_TRACK_S1_SPECKLE_FILTER=lee
MARINE_TRACK_S1_LEE_WINDOW_PX=5
# Sentinel-2 needs B02/B03/B04/B08 plus SCL/cloud/water masks; keep disabled in production.
MARINE_TRACK_ENABLE_SENTINEL2_SINGLE_BAND_EXPERIMENTAL=0
# Hough/Kelvin enrichment is research-only and disabled in the operational path.
MARINE_TRACK_ENABLE_WAKE_RESEARCH=0
# Inter-process timeout while another worker creates the same raster cache target.
MARINE_TRACK_RASTER_LOCK_TIMEOUT_S=300

# Fail-closed AOI and processing workload limits.
MARINE_TRACK_MAX_AOI_AREA_KM2=25000
MARINE_TRACK_MAX_AOI_VERTICES=5000
MARINE_TRACK_MAX_RASTER_PIXELS=2000000000
MARINE_TRACK_MAX_TILES=20000
MARINE_TRACK_MAX_CANDIDATES=10000

# Optional code-version override when the source tree has no .git metadata.
# Production deploy writes code/release identity into current/release.env.
MARINE_TRACK_CODE_VERSION=
MARINE_TRACK_RELEASE_ID=
# Remote GeoTIFF/COG range-read canary before materialization.
MARINE_TRACK_ASSET_PROBE_TIMEOUT_S=30
MARINE_TRACK_ASSET_PROBE_BYTES=4096

# Explicit administrator/CLI live Sentinel-1 self-test. It is never run on startup.
# Leave AOI empty to derive a compact sector from MARINE_TRACK_DEFAULT_AOI.
MARINE_TRACK_CANARY_AOI=
MARINE_TRACK_CANARY_SIDE_KM=8
MARINE_TRACK_CANARY_MAX_AREA_KM2=100
MARINE_TRACK_CANARY_LOOKBACK_HOURS=168
MARINE_TRACK_CANARY_MAX_RESULTS=5

# Administrator human-in-the-loop candidate calibration.
MARINE_TRACK_CALIBRATION_MIN_LABELS=20
MARINE_TRACK_CALIBRATION_MIN_POSITIVE=5
MARINE_TRACK_CALIBRATION_MIN_NEGATIVE=5
MARINE_TRACK_CALIBRATION_CROP_SIZE_PX=768

# Phase 2: detector-independent tiles, held-out evaluation and profile promotion.
MARINE_TRACK_CALIBRATION_PHASE2_MAX_TILES_PER_SCENE=24
MARINE_TRACK_CALIBRATION_PHASE2_MIN_VALID_FRACTION=0.85
MARINE_TRACK_CALIBRATION_PHASE2_MIN_TEST_GROUPS=3
MARINE_TRACK_CALIBRATION_PHASE2_MIN_VALIDATION_GROUPS=3
MARINE_TRACK_CALIBRATION_PHASE2_MIN_IMPROVEMENT=0.01
MARINE_TRACK_CALIBRATION_PHASE2_BOOTSTRAP_SAMPLES=300
# Optional GeoJSON polygons with properties.stratum:
# coastline, port, offshore_structure, open_sea or high_clutter.
MARINE_TRACK_CALIBRATION_CONTEXT_GEOJSON=

# Optional land/shoreline suppression.
MARINE_TRACK_LAND_MASK_GEOJSON=
MARINE_TRACK_SHORELINE_BUFFER_M=500
MARINE_TRACK_AUTO_UPDATE_LAND_MASK=1
MARINE_TRACK_FORCE_UPDATE_LAND_MASK=0
MARINE_TRACK_LAND_MASK_SOURCE_URL=https://naturalearth.s3.amazonaws.com/10m_physical/ne_10m_land.zip
MARINE_TRACK_LAND_MASK_CACHE_DIR=data/masks/cache

# NASA Earthdata / ASF. Optional for search/download paths that require ASF auth.
# Register: https://urs.earthdata.nasa.gov/users/new
# Generate/manage token: https://urs.earthdata.nasa.gov/documentation/for_users/user_token
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
EARTHDATA_TOKEN=

# Copernicus Data Space Ecosystem STAC/OData access. Optional. Empty credentials
# disable CDSE raster OAuth; tokenless Planetary Computer remains available.
# Account: https://dataspace.copernicus.eu/
# Token documentation: https://documentation.dataspace.copernicus.eu/APIs/Token.html
CDSE_ACCESS_TOKEN=
CDSE_STAC_URL=https://stac.dataspace.copernicus.eu/v1/
CDSE_STAC_SENTINEL1_COLLECTION=sentinel-1-grd
CDSE_STAC_SENTINEL2_COLLECTION=sentinel-2-l2a
CDSE_ODATA_URL=https://catalogue.dataspace.copernicus.eu/odata/v1/Products
CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
CDSE_CLIENT_ID=cdse-public
CDSE_CLIENT_SECRET=
CDSE_USERNAME=
CDSE_PASSWORD=

# Sentinel Hub Catalog/Process access. Optional. Empty credentials disable this provider.
# Dashboard/OAuth clients: https://apps.sentinel-hub.com/dashboard/
# Authentication guide: https://docs.sentinel-hub.com/api/latest/api/overview/authentication/
SENTINELHUB_ACCESS_TOKEN=
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
SENTINELHUB_TOKEN_URL=https://services.sentinel-hub.com/auth/realms/main/protocol/openid-connect/token
SENTINELHUB_CATALOG_URL=https://services.sentinel-hub.com/api/v1/catalog/1.0.0/search

# Copernicus Marine Toolbox. Requires provider profile all or aux.
# Register/login: https://data.marine.copernicus.eu/register
COPERNICUSMARINE_SERVICE_USERNAME=
COPERNICUSMARINE_SERVICE_PASSWORD=

# AIS external reference. AIS never overwrites own-system speed/heading and is not unconditional ground truth.
MARINE_TRACK_AIS_CSV=
MARINE_TRACK_AIS_MATCH_WINDOW_MIN=30
MARINE_TRACK_AIS_TRACK_WINDOW_MIN=60
MARINE_TRACK_AIS_MAX_DISTANCE_M=3000
# Reject interpolation across larger AIS reporting gaps.
MARINE_TRACK_AIS_MAX_INTERPOLATION_GAP_MIN=20
# Mark a reference ambiguous when the nearest/second-nearest distance margin is smaller.
MARINE_TRACK_AIS_AMBIGUITY_MARGIN_M=500
NOAA_MARINECADASTRE_BASE_URL=
NOAA_MARINECADASTRE_CACHE_DIR=runs/noaa_ais

# Runtime
PYTHONUNBUFFERED=1

# Runtime health/deployment
MARINE_TRACK_HEALTH_MIN_FREE_MB=512
MARINE_TRACK_KEEP_RELEASES=5
